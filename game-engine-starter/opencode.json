{
  "$schema": "https://opencode.ai/config.json",
  
  "model": "anthropic/claude-sonnet-4-20250514",
  "small_model": "anthropic/claude-haiku-4-20250514",
  
  "agent": {
    "python-reviewer": {
      "description": "Python 代码审查专家",
      "mode": "subagent",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "performance-analyst": {
      "description": "游戏性能分析师",
      "mode": "subagent",
      "tools": {
        "bash": true
      },
      "permission": {
        "bash": {
          "python *": "allow",
          "pylint *": "allow",
          "mypy *": "allow",
          "pytest *": "allow"
        }
      }
    },
    "game-tester": {
      "description": "游戏测试工程师",
      "mode": "subagent",
      "tools": {
        "write": true,
        "bash": true
      }
    },
    "engine-tester": {
      "description": "引擎测试工程师（Mock 架构）",
      "mode": "subagent",
      "tools": {
        "write": true,
        "bash": true
      },
      "permission": {
        "bash": {
          "pytest *": "allow",
          "python -m pytest *": "allow"
        }
      }
    },
    "e2e-tester": {
      "description": "E2E 测试工程师（Socket 通信）",
      "mode": "subagent",
      "tools": {
        "write": true,
        "bash": true
      },
      "permission": {
        "bash": {
          "pytest tests/e2e *": "allow",
          "python tests/e2e/*": "allow",
          "python main.py --test-mode*": "allow"
        }
      }
    }
  },
  
  "command": {
    "run": {
      "template": "运行游戏",
      "description": "启动游戏",
      "agent": "build"
    },
    "test": {
      "template": "运行测试",
      "description": "运行测试套件",
      "agent": "build"
    },
    "lint": {
      "template": "代码检查",
      "description": "运行代码质量检查",
      "agent": "plan"
    },
    "profile": {
      "template": "性能分析",
      "description": "运行性能分析",
      "agent": "build"
    },
    "benchmark": {
      "template": "运行基准测试",
      "description": "运行性能基准测试",
      "agent": "build"
    },
    "stress": {
      "template": "运行压力测试",
      "description": "运行压力测试",
      "agent": "build"
    },
    "coverage": {
      "template": "生成覆盖率报告",
      "description": "运行测试覆盖率分析",
      "agent": "build"
    },
    "e2e": {
      "template": "运行 E2E 测试",
      "description": "运行 E2E 测试（Socket 通信）",
      "agent": "build"
    },
    "generate-socket-test": {
      "template": "生成 Socket 测试代码模板",
      "description": "为指定功能生成测试代码",
      "agent": "build"
    },
    "generate-entity": {
      "template": "生成实体类",
      "description": "创建实体类模板",
      "agent": "build"
    }
  },
  
  "permission": {
    "edit": "ask",
    "bash": {
      "git push": "ask",
      "pip install *": "ask",
      "rm -rf *": "deny"
    },
    "skill": {
      "*": "allow"
    }
  },
  
  "instructions": [
    ".opencode/AGENTS.md"
  ],
  
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  
  "watcher": {
    "ignore": [
      "__pycache__/**",
      "*.pyc",
      ".pytest_cache/**",
      ".mypy_cache/**",
      "*.egg-info/**",
      "build/**",
      "dist/**",
      ".benchmarks/**",
      "htmlcov/**"
    ]
  }
}
